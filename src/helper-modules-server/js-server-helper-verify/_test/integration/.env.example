# Connection strings for the verify integration test suite.
# Defaults match the docker-compose.yml in this directory.
# Copy to `.env` and source it before running `npm test`:
#   cp .env.example .env
#   set -a && source .env && set +a
#   npm test

# ============================================================================
# SQL backends
# ============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=test_db
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_pw

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=test_db
MYSQL_USER=test_user
MYSQL_PASSWORD=test_pw

# SQLite runs in-memory by default - leave SQLITE_FILE unset to use :memory:
# SQLITE_FILE=/tmp/verify-test.db

VERIFY_TEST_SQL_TABLE=verification_codes


# ============================================================================
# MongoDB
# ============================================================================

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=verify_test
MONGODB_COLLECTION=verification_codes


# ============================================================================
# DynamoDB Local
# ============================================================================

DYNAMODB_TABLE=verification_codes
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
