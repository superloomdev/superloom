{
  "name": "js-server-helper-verify-integration-tests",
  "description": "Integration test suite for js-server-helper-verify against Postgres, MySQL, SQLite, MongoDB, DynamoDB",
  "version": "1.0.1",
  "main": "test.js",
  "private": true,
  "license": "MIT",
  "author": "Superloom <hi@superloom.dev>",
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@superloomdev/js-helper-utils": "1.0.1",
    "@superloomdev/js-helper-debug": "1.0.1",
    "@superloomdev/js-server-helper-crypto": "1.0.1",
    "@superloomdev/js-server-helper-instance": "1.0.1",
    "@superloomdev/js-server-helper-sql-postgres": "1.0.1",
    "@superloomdev/js-server-helper-sql-mysql": "1.0.1",
    "@superloomdev/js-server-helper-sql-sqlite": "1.0.1",
    "@superloomdev/js-server-helper-nosql-mongodb": "1.0.1",
    "@superloomdev/js-server-helper-nosql-aws-dynamodb": "1.0.1",
    "@aws-sdk/client-dynamodb": "^3.665.0",
