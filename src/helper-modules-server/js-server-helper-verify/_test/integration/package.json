    "mongodb": "^6.10.0",
    "pg": "^8.11.0",
    "mysql2": "^3.11.0"
  },
  "scripts": {
    "pretest": "docker compose down -v --remove-orphans 2>/dev/null; docker compose up -d --wait && sleep 10",
