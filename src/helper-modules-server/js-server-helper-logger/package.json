  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "helper-utils": "npm:@superloomdev/js-helper-utils@>=1.0.0",
    "helper-debug": "npm:@superloomdev/js-helper-debug@>=1.0.0",
    "helper-crypto": "npm:@superloomdev/js-server-helper-crypto@>=1.0.0",
    "helper-instance": "npm:@superloomdev/js-server-helper-instance@>=1.0.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.1"
