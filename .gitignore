# Dependencies
node_modules/
package-lock.json

# Personal dev workspace (machine-specific, never committed)
__dev__/

# Legacy cleanup folder (never committed)
_cleanup/

# IDE workspace files (machine-specific)
*.code-workspace

# Work in progress (personal planning, never committed)
wip/

# Environment files (never commit secrets)
.env
.env.*

# Config with secrets
config/

# OS files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
._*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
DIST/
build/

# npmrc files (never commit registry credentials anywhere)
# Exception: root .npmrc contains only scope routing, no tokens — safe to commit
**/.npmrc
!/.npmrc

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SQLite artefacts (generated inside _test/ during testing — scoped to avoid matching production data files)
**/_test/*.db
**/_test/*.sqlite
**/_test/*.sqlite3
**/_test/*.db-journal
**/_test/*.db-wal
**/_test/*.db-shm

# npm cache directory
.npm

# Serverless Framework cache
.serverless

# Website: rsync-copied from ../docs/ during CI build temporarily (not source)
# Docs source-of-truth is at /docs in repo root; website/docs/ is temp build artifact
# Required because VitePress only supports single srcDir - cannot reference ../docs/
# Sidebar/nav links use /docs/ paths which must exist within srcDir during build
website/docs/
website/.vitepress/cache/
website/DIST/
