# Superloom - Dev Environment Variables
# Copy this file to __dev__/.env.dev and fill in your values.
# This file is committed. __dev__/.env.dev is NOT committed.
# Load into your shell: source init-env.sh (select option 1)

# --- GitHub Packages ---
# Required for Approach 1 (@your-org/*) and Approach 3 (@superloomdev/*)
# Not needed for Approach 2 (Local Copy) since it uses file: references
# Token for installing packages from GitHub Packages
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Name: read-packages-token | Scope: read:packages
GITHUB_READ_PACKAGES_TOKEN=your-token-here

# --- General ---
NODE_ENV=dev
APP_NAME=open-framework
APP_PORT=3000

# --- PostgreSQL (docker-compose: postgres) ---
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_DATABASE=app_dev
DB_POSTGRES_USER=dev_user
DB_POSTGRES_PASSWORD=dev_password
DB_POSTGRES_POOL_MAX=5
DB_POSTGRES_POOL_MIN=0

# --- MySQL (docker-compose: mysql) ---
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=app_dev
DB_MYSQL_USER=dev_user
DB_MYSQL_PASSWORD=dev_password
DB_MYSQL_POOL_MAX=5
DB_MYSQL_POOL_MIN=0

# --- MongoDB (docker-compose: mongodb) ---
DB_MONGO_HOST=localhost
DB_MONGO_PORT=27017
DB_MONGO_DATABASE=app_dev
DB_MONGO_USER=
DB_MONGO_PASSWORD=

# --- MySQL module tests (_test/docker-compose.yml) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=test_db
MYSQL_USER=test_user
MYSQL_PASSWORD=test_pw
MYSQL_ROOT_PASSWORD=test_root_pw

# --- Postgres module tests (_test/docker-compose.yml) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=test_db
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_pw

# --- DynamoDB Local (docker-compose: dynamodb or _test/docker-compose.yml) ---
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000

# --- S3-Compatible Storage via MinIO (docker-compose: minio) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=dev_access_key
S3_SECRET_KEY=dev_secret_key
S3_BUCKET_MEDIA=dev-media
S3_BUCKET_UPLOADS=dev-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- SQS via ElasticMQ (docker-compose: elasticmq or _test/docker-compose.yml) ---
# Uses shared AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION from DynamoDB section above
SQS_ENDPOINT=http://localhost:9324

# --- Auth / Crypto (application-level) ---
AUTH_TOKEN_SALT=change-this-in-sandbox-and-prod
ENCRYPTION_KEY=change-this-in-sandbox-and-prod
