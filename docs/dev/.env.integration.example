# Superloom - Integration Environment Variables
# Copy this file to __dev__/.env.integration and fill in your values.
# This file is committed. __dev__/.env.integration is NOT committed.
# Load into your shell: source init-env.sh (select option 2: integration)
# Uses real cloud services in an isolated sandbox AWS account.

# --- GitHub Packages ---
# Required for Approach 1 (@your-org/*) and Approach 3 (@superloomdev/*)
# Not needed for Approach 2 (Local Copy) since it uses file: references
# Token for installing packages from GitHub Packages
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Name: read-packages-token | Scope: read:packages
GITHUB_READ_PACKAGES_TOKEN=your-token-here

# --- General ---
NODE_ENV=integration
APP_NAME=open-framework
APP_PORT=3000

# --- PostgreSQL (AWS Aurora or remote) ---
DB_POSTGRES_HOST=your-sandbox-db-host
DB_POSTGRES_PORT=5432
DB_POSTGRES_DATABASE=app_sandbox
DB_POSTGRES_USER=your-db-user
DB_POSTGRES_PASSWORD=your-db-password
DB_POSTGRES_POOL_MAX=5
DB_POSTGRES_POOL_MIN=0

# --- MySQL (remote) ---
DB_MYSQL_HOST=your-sandbox-db-host
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=app_sandbox
DB_MYSQL_USER=your-db-user
DB_MYSQL_PASSWORD=your-db-password
DB_MYSQL_POOL_MAX=5
DB_MYSQL_POOL_MIN=0

# --- MongoDB (Atlas or remote) ---
DB_MONGO_HOST=your-sandbox-mongo-host
DB_MONGO_PORT=27017
DB_MONGO_DATABASE=app_sandbox
DB_MONGO_USER=your-mongo-user
DB_MONGO_PASSWORD=your-mongo-password

# --- MySQL module tests (real AWS Aurora MySQL 3 sandbox) ---
MYSQL_HOST=your-aurora-mysql-cluster-endpoint
MYSQL_PORT=3306
MYSQL_DATABASE=test_db
MYSQL_USER=unit_tester
MYSQL_PASSWORD=your-sandbox-mysql-password
MYSQL_ROOT_PASSWORD=your-sandbox-mysql-master-password

# --- Postgres module tests (real AWS Aurora Postgres sandbox) ---
POSTGRES_HOST=your-aurora-postgres-cluster-endpoint
POSTGRES_PORT=5432
POSTGRES_DATABASE=test_db
POSTGRES_USER=unit_tester
POSTGRES_PASSWORD=your-sandbox-postgres-password

# --- DynamoDB (real AWS - no ENDPOINT override) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT is intentionally NOT set - SDK uses real AWS DynamoDB

# --- S3 (AWS) ---
# S3_ENDPOINT is intentionally NOT set - SDK uses real AWS S3
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key
S3_BUCKET_MEDIA=sandbox-media
S3_BUCKET_UPLOADS=sandbox-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false

# --- SQS (AWS) ---
# SQS_ENDPOINT is intentionally NOT set - SDK uses real AWS SQS
# Uses shared AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION from DynamoDB section above

# --- Auth / Crypto (application-level) ---
AUTH_TOKEN_SALT=change-this-in-sandbox-and-prod
ENCRYPTION_KEY=change-this-in-sandbox-and-prod
